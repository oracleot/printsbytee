# Runtime mode. Defaults to "development" if unset.
NODE_ENV=development

# HTTP port the API binds to. Defaults to 3000.
PORT=3000

# Postgres connection string. Required. Railway provides this as
# DATABASE_URL on the API service once Postgres is attached.
DATABASE_URL=postgresql://user:password@localhost:5432/printsbytee

# Secret used to sign/derive session tokens. Required. Use a long random
# value in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=replace-me-with-a-long-random-string

# Shared secret the website/business-app must send to call internal-only
# endpoints. Required. Use a long random value in production.
INTERNAL_API_KEY=replace-me-with-a-long-random-string

# --- SMTP (used by POST /enquiries; optional until I16) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Recipient address for enquiry notifications.
ENQUIRY_EMAIL=

# --- Cloudflare R2 (used by POST /uploads; optional until I22) ---
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public base URL for R2 objects (e.g. https://images.example.com).
R2_PUBLIC_BASE_URL=