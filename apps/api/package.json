{
  "name": "@printsbytee/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "predev": "corepack pnpm@9.0.0 --filter @printsbytee/shared build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "corepack pnpm@9.0.0 --filter @printsbytee/shared build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretypecheck": "corepack pnpm@9.0.0 --filter @printsbytee/shared build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "prelint": "corepack pnpm@9.0.0 --filter @printsbytee/shared build",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "upload:website-images": "tsx scripts/upload-website-images-to-r2.ts",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@hono/node-server": "^1.19.0",
    "@printsbytee/shared": "file:../../packages/shared",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.12.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
